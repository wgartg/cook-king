rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /recipes/{recipeId} {
      allow read: if true;

      // 投稿にはDiscordログイン(Firebase Auth)が必須。
      // authorIdはログイン中の自分のuidと一致していなければならない(なりすまし防止)。
      allow create: if request.auth != null
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() < 200
                    && request.resource.data.ingredients is list
                    && request.resource.data.steps is list
                    && request.resource.data.authorId == request.auth.uid;

      // 削除は「投稿した本人」または「admin権限を持つDiscordユーザー」のみ。
      // admin権限はCloudflare Worker側でカスタムクレーム(admin: true)として付与される。
      allow delete: if request.auth != null
                    && (request.auth.token.admin == true
                        || resource.data.authorId == request.auth.uid);

      // 更新は2パターンのみ許可:
      // ① 投稿した本人 or admin による、内容の編集(authorIdは変更不可)
      // ② ログイン中の誰でも、いいね(likedBy/likesCount)だけを変更する場合
      allow update: if request.auth != null && (
        (
          (resource.data.authorId == request.auth.uid || request.auth.token.admin == true)
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() < 200
          && request.resource.data.ingredients is list
          && request.resource.data.steps is list
        )
        ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likedBy", "likesCount"])
      );
    }
  }
}
